{
  "name": "royal-club-whatsapp-automation",
  "version": "2.0.0",
  "description": "WhatsApp Sales Automation for Royal Club - MC Daniel Falcão Show",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "setup": "npm run prisma:generate && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@types/fs-extra": "^11.0.4",
    "@whiskeysockets/baileys": "^6.7.8",
    "@wppconnect-team/wppconnect": "^1.37.3",
    "archiver": "^6.0.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.1.1",
    "helmet": "^7.1.0",
    "node-fetch": "^2.7.0",
    "pino": "^8.21.0",
    "pino-pretty": "^10.2.3",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^2.4.2",
    "redis": "^5.8.0",
    "stripe": "^14.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.4",
    "@types/node-fetch": "^2.6.9",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "prisma": "^5.7.1",
    "supertest": "^6.3.3",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "whatsapp",
    "automation",
    "sales",
    "royal-club",
    "mc-daniel",
    "typescript",
    "clean-architecture"
  ],
  "author": "Royal Club",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
