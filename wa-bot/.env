# Royal Club WhatsApp Bot Configuration
CLUB_NAME=Royal Club
PORT=8080
NODE_ENV=production

# Redis Configuration
REDIS_URL=redis://dave_redis:6379

# Rate Limiting
RATE_LIMIT_MSGS_PER_MIN=12

# WhatsApp Configuration
WA_SESSION_PATH=./storage/session
WA_LOG_LEVEL=info

# API Configuration
API_CORS_ENABLED=true
API_RATE_LIMIT_ENABLED=true
