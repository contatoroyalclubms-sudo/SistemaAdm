# WhatsApp Bot Configuration
CLUB_NAME=Royal Club
PORT=8080

# WhatsApp Session
WA_SESSION_PATH=./storage/session

# Logging
WA_LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MSGS_PER_MIN=12
API_RATE_LIMIT_ENABLED=true

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Configuration
API_CORS_ENABLED=true

# PIX Payment Configuration (STUB - Replace with real provider)
PIX_API_KEY=your-pix-api-key
PIX_WEBHOOK_URL=http://localhost:8080/webhook/pix

